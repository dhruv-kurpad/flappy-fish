{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "FlappyFish game."
  },
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "flappy-fish",
      "metadata": {
        "description": "Name of the Azure Container Instance group."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the container group."
      }
    },
    "acrServer": {
      "type": "string",
      "metadata": {
        "description": "Azure Container Registry login server, e.g. myregistry.azurecr.io"
      }
    },
    "acrUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "ACR username (admin user or service principal). Leave empty if images are public."
      }
    },
    "acrPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "ACR password or service principal secret."
      }
    },
    "flaskApiImage": {
      "type": "string",
      "defaultValue": "flask-api:latest",
      "metadata": {
        "description": "Flask DB API image — build from src/Dockerfile.web (compose service: flask-api)."
      }
    },
    "gameServerImage": {
      "type": "string",
      "defaultValue": "game-server:latest",
      "metadata": {
        "description": "FastAPI game server image — build from src/Dockerfile.game (compose service: game-server)."
      }
    },
    "frontendImage": {
      "type": "string",
      "defaultValue": "frontend:latest",
      "metadata": {
        "description": "React + nginx image — build from frontend/Dockerfile.react (compose service: frontend)."
      }
    },
    "sqlServer": {
      "type": "string",
      "defaultValue": "tcp:flappy-fish.database.windows.net,1433",
      "metadata": {
        "description": "Azure SQL server (for future env-based config in flaskapp_pool.py)."
      }
    },
    "sqlDatabase": {
      "type": "string",
      "defaultValue": "flappy-fish",
      "metadata": {
        "description": "Azure SQL database name."
      }
    },
    "sqlUsername": {
      "type": "string",
      "metadata": {
        "description": "Azure SQL login username."
      }
    },
    "sqlPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Azure SQL login password."
      }
    }
  },
  "variables": {
    "flaskApiContainerName": "flask-api",
    "gameServerContainerName": "game-server",
    "frontendContainerName": "frontend",
    "flaskApiImageRef": "[concat(parameters('acrServer'), '/', parameters('flaskApiImage'))]",
    "gameServerImageRef": "[concat(parameters('acrServer'), '/', parameters('gameServerImage'))]",
    "frontendImageRef": "[concat(parameters('acrServer'), '/', parameters('frontendImage'))]",
    "useAcrAuth": "[not(equals(parameters('acrUsername'), ''))]"
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "osType": "Linux",
        "restartPolicy": "Always",
        "imageRegistryCredentials": "[if(variables('useAcrAuth'), createArray(createObject('server', parameters('acrServer'), 'username', parameters('acrUsername'), 'password', parameters('acrPassword'))), createArray())]",
        "ipAddress": {
          "type": "Public",
          "dnsNameLabel": "[parameters('containerGroupName')]",
          "ports": [
            {
              "protocol": "TCP",
              "port": 80
            }
          ]
        },
        "containers": [
          {
            "name": "[variables('flaskApiContainerName')]",
            "properties": {
              "image": "[variables('flaskApiImageRef')]",
              "ports": [
                {
                  "port": 5000,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "PORT",
                  "value": "5000"
                },
                {
                  "name": "SERVER",
                  "value": "[parameters('sqlServer')]"
                },
                {
                  "name": "DATABASE",
                  "value": "[parameters('sqlDatabase')]"
                },
                {
                  "name": "UID",
                  "value": "[parameters('sqlUsername')]"
                },
                {
                  "name": "PWD",
                  "secureValue": "[parameters('sqlPassword')]"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGB": 1.5
                }
              }
            }
          },
          {
            "name": "[variables('gameServerContainerName')]",
            "properties": {
              "image": "[variables('gameServerImageRef')]",
              "ports": [
                {
                  "port": 8765,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "PORT",
                  "value": "8765"
                },
                {
                  "name": "BASE_URL",
                  "value": "http://127.0.0.1:5000"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGB": 1.0
                }
              }
            }
          },
          {
            "name": "[variables('frontendContainerName')]",
            "properties": {
              "image": "[variables('frontendImageRef')]",
              "ports": [
                {
                  "port": 80,
                  "protocol": "TCP"
                }
              ],
              "command": [
                "/bin/sh",
                "-c",
                "sed -i 's|http://game-server:8765|http://127.0.0.1:8765|g' /etc/nginx/conf.d/default.conf && exec nginx -g 'daemon off;'"
              ],
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 0.5
                }
              }
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "containerGroupName": {
      "type": "string",
      "value": "[parameters('containerGroupName')]"
    },
    "publicIpAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName')), '2023-05-01').ipAddress.ip]"
    },
    "fqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName')), '2023-05-01').ipAddress.fqdn]"
    },
    "appUrl": {
      "type": "string",
      "value": "[concat('http://', reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName')), '2023-05-01').ipAddress.fqdn)]"
    }
  }
}
