# GitHub Repository Secrets checklist
# Add at: GitHub repo → Settings → Secrets and variables → Actions → New repository secret
#
# Do NOT commit real values. Keep them in GitHub only.
# Optional: copy this list to deploy.secrets.env locally as a personal worksheet.

# --- Your 7 (ACR + deploy + SQL) ---
ACR_NAME=
ACR_LOGIN_SERVER=
ACR_USERNAME=
ACR_PASSWORD=
AZURE_RESOURCE_GROUP=
SQL_USERNAME=
SQL_PASSWORD=

# --- Also required for az login in deploy.yml (service principal) ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ACR_LOGIN_SERVER = usually <ACR_NAME>.azurecr.io
# ACR_NAME is not read by deploy.yml — use ACR_LOGIN_SERVER in the workflow.
