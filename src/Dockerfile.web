# Flask DB API (flaskapp_pool.py)
# Build:  docker build -f Dockerfile.web -t web-server ./src
# Run:    docker run -p 5000:5000 web-server

FROM python:3.12-bookworm

# Microsoft ODBC Driver 18 for Azure SQL
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gnupg unixodbc-dev \
    && curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg \
    && echo "deb [arch=amd64,arm64,armhf signed-by=/usr/share/keyrings/microsoft-prod.gpg] https://packages.microsoft.com/debian/12/prod bookworm main" > /etc/apt/sources.list.d/mssql-release.list \
    && apt-get update \
    && ACCEPT_EULA=Y apt-get install -y msodbcsql18 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir \
    "flask>=3.0.0" \
    "pyodbc>=5.0.0" \
    "dbutils>=3.0.0" \
    gunicorn

COPY flaskapp_pool.py ./

ENV PORT=5000
EXPOSE 5000

CMD ["gunicorn", "-b", "0.0.0.0:5000", "-w", "2", "flaskapp_pool:app"]
